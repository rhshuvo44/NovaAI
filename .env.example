# ==============================================================================
# AI Workspace Frontend - Environment Configuration
# Copy to .env.local and fill in real values.
# ==============================================================================

# --- Backend API ---
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# --- Clerk Authentication ---
# https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Optional: enables a "Try the live demo" button on the login page that
# signs straight into a pre-provisioned demo account. Leave unset to hide it.
NEXT_PUBLIC_DEMO_ACCOUNT_EMAIL=
NEXT_PUBLIC_DEMO_ACCOUNT_PASSWORD=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=AI Workspace
